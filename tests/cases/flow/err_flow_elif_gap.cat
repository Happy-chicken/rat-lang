// @fail
// @error: not all control paths return a value

def grade(score: int) -> str {
    if score > 90 {
        return "A";
    } elif score > 80 {
        return "B";
    } elif score > 70 {
        return "C";
    } elif score > 60 {
        let pass: bool = true;
    } else {
        return "F";
    }
}
